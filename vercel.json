{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/auth/(.*)", "dest": "/api/index.py" },
    { "src": "/s3/(.*)", "dest": "/api/index.py" },
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/frontend/(.*)", "dest": "/frontend/$1" },
    { "src": "/", "dest": "/frontend/index.html" }
  ]
}
